                        </svg>
                    </span>
                </button>
                <div class="faq-answer" style="display:none;"><p>Resposta da segunda pergunta.</p></div>
            </div>
            <div class="faq-item">
                <button class="faq-question" aria-expanded="false">
                    Terceira pergunta
