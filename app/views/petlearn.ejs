    <div id="faq">   
        <h1 id="faq-title">Dúvidas Frequentes</h1>
        <div id="faq-questions">
            <div class="faq-item">
                <button class="faq-question" aria-expanded="false">
                    Primeira pergunta
                    <span class="faq-chevron">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M8 10L12 14L16 10" stroke="#6B9950" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </span>
                </button>
                <div class="faq-answer" style="display:none;"><p>Resposta da primeira pergunta.</p></div>
            </div>
            <div class="faq-item">
                <button class="faq-question" aria-expanded="false">
                    Segunda pergunta
                    <span class="faq-chevron">
                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
